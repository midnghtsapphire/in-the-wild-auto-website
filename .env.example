# ─── InTheWild — Environment Variables Template ───────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database (MySQL 8.0) ──────────────────────────────────────────────────────
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
# Local dev:     mysql://inthewild:password@localhost:3306/inthewild
# DigitalOcean Managed MySQL (production):
#   mysql://USER:PASSWORD@db-mysql-xxxx.b.db.ondigitalocean.com:25060/inthewild?ssl=true
DATABASE_URL=mysql://inthewild:password@localhost:3306/inthewild

# Docker Compose only (used by the `db` service):
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=inthewild
MYSQL_USER=inthewild
MYSQL_PASSWORD=password

# ── Authentication ────────────────────────────────────────────────────────────
# Must be at least 32 random characters. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-a-very-long-random-secret-string-here

# ── OAuth (Manus built-in auth platform) ─────────────────────────────────────
# Leave empty if you are only using email/password auth.
OAUTH_SERVER_URL=
OWNER_OPEN_ID=
VITE_APP_ID=

# ── OpenRouter (LLM generation) ───────────────────────────────────────────────
# Get your free key at https://openrouter.ai
# This is the only required API key to get the generator working.
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Stripe (billing) ──────────────────────────────────────────────────────────
# Set STRIPE_MODE=test during development, live for production.
# Get keys at https://dashboard.stripe.com/apikeys
STRIPE_MODE=test
STRIPE_TEST_SECRET_KEY=sk_test_YOUR_TEST_SECRET_KEY
STRIPE_TEST_PUBLISHABLE_KEY=pk_test_YOUR_TEST_PUBLISHABLE_KEY
STRIPE_LIVE_SECRET_KEY=sk_live_YOUR_LIVE_SECRET_KEY
STRIPE_LIVE_PUBLISHABLE_KEY=pk_live_YOUR_LIVE_PUBLISHABLE_KEY

# ── Analytics (optional Umami analytics) ─────────────────────────────────────
# Self-hosted Umami instance. Leave empty to disable.
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# ── MCP Microservice URLs (optional) ─────────────────────────────────────────
# Leave empty to disable individual services.
# When using docker-compose, these are set automatically.
# When deploying to DigitalOcean App Platform, set these to your DO App service URLs.
MCP_WEBSITE_GENERATOR_URL=
MCP_ANALYTICS_URL=
MCP_PAYMENT_URL=
MCP_SEO_URL=
MCP_CODE_REVIEW_URL=
MCP_AI_CHAT_URL=

# ── AWS S3 (optional — for storing generated project files) ───────────────────
# Leave empty to store files only in the database.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# ── Forge API (Manus internal, leave as-is) ──────────────────────────────────
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
